# ============================================================
# .env.example — copy to .env for local development
# ============================================================
# NEVER commit .env or any real credential to version control.
# Actual secrets (API keys, passwords) must be stored in AWS
# Secrets Manager. Only non-sensitive runtime config goes here.
# ============================================================

# ----- AWS (required) ----------------------------------------
AWS_REGION=ap-northeast-1
# AWS_PROFILE=your-sso-profile   # optional: local dev only
SECRET_CACHE_TTL=300             # seconds between re-fetches

# ----- LLM ---------------------------------------------------
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# ----- RAG ---------------------------------------------------
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_STORE_PATH=./data/vector_store
RAG_TOP_K=5
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64

# ----- App ---------------------------------------------------
LOG_LEVEL=INFO
