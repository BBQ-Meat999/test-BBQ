# ============================================================
# .env.example — copy to .env for local development
# ============================================================
# NEVER commit .env or any real credential to version control.
# Actual secrets (API keys, passwords) must be stored in AWS
# Secrets Manager. Only non-sensitive runtime config goes here.
# ============================================================

# ----- AWS (required) ----------------------------------------
AWS_REGION=ap-northeast-1
# AWS_PROFILE=your-sso-profile   # optional: local dev only
SECRET_CACHE_TTL=300             # seconds between re-fetches

# ----- LLM ---------------------------------------------------
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# ----- Workflow ----------------------------------------------
MAX_REVIEW_LOOPS=2               # 実装↔レビューの最大往復回数
MAX_CONTEXT_MESSAGES=20          # messages 保持上限 (コンテキスト圧縮)
REQUIRE_PLAN_APPROVAL=true       # 作業計画を interrupt() で人間承認するか

# ----- App ---------------------------------------------------
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8080

# ----- Discord (任意) -----------------------------------------
# BOT トークンは AWS Secrets Manager に格納する (env に直書きしない)
#   AWS コンソール / CLI でシークレットを作成:
#     aws secretsmanager create-secret \
#       --name multiagent-rag/external-services \
#       --secret-string '{"discord_bot_token":"Bot xxxxxx..."}'
#
# 成果物を投稿するチャンネルの ID (数字のみ・非機密なので env に書いてよい)
#   Discord チャンネルを右クリック → "チャンネルIDをコピー" で取得
DISCORD_DELIVERY_CHANNEL_ID=
